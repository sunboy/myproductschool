# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local dev runtime artifacts
.next-dev.log
.next-dev.pid
.stripe-listen.log
.stripe-listen.pid
tmp/

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# git worktrees
.worktrees/

# local tooling (Claude Code, Playwright MCP, Superpowers)
.codex/
.claire/
.claude/
.playwright-mcp/
.superpowers/
__pycache__/
*.pyc

# local credentials
hackproduct-*.json

# enrichment intermediates / backups (never commit)
.autopsy-image-batches/
seeds/staged-interview-challenges.backup-*.json
seeds/reenrich-shard-*.json
seeds/reenrich-sonnet-shard-*.json
seeds/algo-fix-shard-*.json
seeds/sql-fix-shard.json
seeds/validate-shard-*.json
